{
  "name": "@croffledev/croffle-sdk",
  "version": "1.0.0",
  "description": "SDK and CLI for creating Croffle plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "create-croffle-plugin": "dist/cli.js",
    "croffle-plugin": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "dev": "tsup src/cli.ts src/index.ts --format esm --watch",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@croffledev/croffle-types": "^1.1.0",
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "packageManager": "yarn@4.13.0"
}
